# Example environment for the API server (services/api).
# Copy to .env and fill in real values. Never commit a real .env (it is gitignored).
#
# The server picks its mode from DATABASE_URL:
#   - DATABASE_URL set  -> persistent mode (Drizzle/RLS + Redis), validated fail-fast.
#   - DATABASE_URL unset -> in-memory dev mode (seeds a demo tenant, port 3001).
#
# Required in persistent mode: DATABASE_URL, REDIS_URL, PLATFORM_BASE_DOMAIN,
# PASSWORDLESS_TOKEN_SECRET, SESSION_COOKIE_SECRET. Everything below those is
# optional until its feature is wired (but validated if you set it).

# ----------------------------------------------------------------------------
# Core (required for persistent mode)
# ----------------------------------------------------------------------------

NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3001

# Domain used to resolve tenant subdomains, e.g. {slug}.reservas.example.
PLATFORM_BASE_DOMAIN=reservas.localhost

# PostgreSQL — connect with a NOSUPERUSER/NOBYPASSRLS role in real environments
# (RLS is the tenant-isolation defense). Local docker-compose default shown.
DATABASE_URL=postgres://saas_admin:saas_admin@localhost:5432/saas_reservas

# Redis — checkout locks, queues, short-lived coordination.
REDIS_URL=redis://localhost:6379

# Session / token signing secrets. Generate with: openssl rand -base64 48
PASSWORDLESS_TOKEN_SECRET=CHANGE_ME_min_32_chars________________________
SESSION_COOKIE_SECRET=CHANGE_ME_min_32_chars________________________

# Platform superadmin (feature 002). Optional: set only where the platform
# surface is wired. Gates the self-locking first-operator bootstrap
# (POST /v1/platform/operators/bootstrap); min 32 chars. Keep this and the
# resulting operator credentials OUT of source control (operator-held / secret
# manager). Unset = the bootstrap endpoint cannot create the first operator.
# PLATFORM_BOOTSTRAP_SECRET=CHANGE_ME_min_32_chars________________________

# Logging
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Admin console data source (apps/admin) — ADR-0018.
# ----------------------------------------------------------------------------
#
# ADMIN_DATA_MODE selects where the admin console reads/writes:
#   - demo (default): in-memory demo store, no backend needed.
#   - api: the persistent Fastify API (this server). Requires the vars below.
# These are consumed by apps/admin (server-side only), not by services/api.
#
# ADMIN_DATA_MODE=api
# API_ORIGIN=http://localhost:3001
# ADMIN_TENANT_HOST=mi-negocio.reservas.localhost
# ADMIN_STAFF_EMAIL=admin@mi-negocio.example
# ADMIN_STAFF_PASSWORD=CHANGE_ME

# ----------------------------------------------------------------------------
# Object storage (optional until the file-attachment pipeline is wired).
# Local MinIO via docker-compose shown; in prod use S3/GCS.
# ----------------------------------------------------------------------------

# STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
# STORAGE_BUCKET=saas-reservas
# STORAGE_ACCESS_KEY_ID=saas-minio
# STORAGE_SECRET_ACCESS_KEY=saas-minio-secret

# ----------------------------------------------------------------------------
# Integration credential vault master key (optional until integrations are
# wired). In production this is fronted by a real KMS CMK. openssl rand -base64 48
# ----------------------------------------------------------------------------

# CREDENTIALS_MASTER_KEY=CHANGE_ME_min_32_chars________________________

# ----------------------------------------------------------------------------
# Per-integration provider secrets (NOT consumed yet — see docs/operations/SETUP.md).
# Most tenant-facing credentials (WhatsApp, tenant Stripe via Connect, tenant
# calendar OAuth) are entered per-tenant in the admin and encrypted by the vault,
# NOT set here. Platform-level secrets (platform Stripe, shared OAuth app,
# email/SMS provider, KMS) will live here once those adapters are wired:
#
# Platform Stripe is WIRED: set STRIPE_SECRET_KEY to switch the API from the
# fake gateway to the real Stripe Connect adapter (destination charges +
# application fee). STRIPE_APPLICATION_FEE_BPS is the platform fee in basis
# points (200 = 2%); STRIPE_API_BASE_URL can point at a mock for smoke tests.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_APPLICATION_FEE_BPS=200
# STRIPE_API_BASE_URL=
#
# Messaging is WIRED for email (Brevo, ex-Sendinblue): set BREVO_API_KEY to switch
# the messaging factory from the fake provider to the real Brevo transactional
# email adapter (free tier: 300 emails/day). MESSAGING_FROM_EMAIL is required when
# the key is set and MUST be a Brevo-verified sender; MESSAGING_FROM_NAME is the
# optional display name. BREVO_API_BASE_URL can point at a mock for smoke tests.
# SMS is NOT wired (Brevo SMS is paid) — SMS sends fall back / are skipped.
# BREVO_API_KEY=
# MESSAGING_FROM_EMAIL=
# MESSAGING_FROM_NAME=
# BREVO_API_BASE_URL=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT_ID=
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# AWS_KMS_KEY_ID=
